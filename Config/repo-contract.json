{
  "name": "HumbleStudio",
  "repo_type": "humble-studio-hybrid",
  "profiles": [
    "humble-studio-hybrid"
  ],
  "module_roots": [
    "AppleApps",
    "js",
    "docs"
  ],
  "locale_policy": {
    "declared_locales": [
      "en",
      "cs"
    ],
    "strategy": "apple-xcstrings-and-web-inline"
  },
  "workflow": {
    "default_branch": "main",
    "requires_tickets": true,
    "branch_hygiene": {
      "rebase_before_local_checks": true,
      "rebase_before_promotion": true,
      "prefer_fast_promotion_after_green": true,
      "delete_merged_topic_branches": true
    },
    "worktree_lanes": {
      "enabled": true,
      "root": "/Users/janpokorny/Coding/personal/worktrees/HumbleStudio",
      "lanes": [
        "lane-1",
        "lane-2",
        "lane-3",
        "lane-4"
      ],
      "reserved_main_checkout": true
    },
    "branch_protection_policy": {
      "default_branch": "main",
      "required_status_checks": {
        "strict": true,
        "contexts": [],
        "checks": []
      },
      "preserve_existing": [
        "required_linear_history",
        "enforce_admins",
        "required_reviews",
        "conversation_resolution",
        "restrictions"
      ],
      "allow_force_pushes": false,
      "allow_deletions": false
    },
    "github_actions_policy": {
      "required_default_branch_checks": false,
      "required_contexts": [],
      "required_checks": [],
      "pull_request_gates": "allowed_only_when_not_required_or_approved_exception",
      "preferred_quality_trigger": "workflow_dispatch",
      "sensitive_workflow_kinds": [
        "release",
        "deploy",
        "notarization",
        "app_store",
        "external_publish"
      ],
      "sensitive_workflows_require_explicit_confirmation": true
    },
    "allowed_workflow_triggers": {
      "quality_and_policy_tools": [
        "workflow_dispatch"
      ],
      "pull_request": "allowed_only_when_not_required_or_approved_exception",
      "push_main": "allowed_only_for_non_blocking_reporting_or_approved_release_deploy"
    },
    "required_checks_policy": {
      "github_actions_required_checks_allowed": false,
      "default_branch_contexts": [],
      "default_branch_checks": []
    },
    "exceptions": [],
    "stale_file_policy": {
      "local_rule_copies": "reference_canonical_contract_or_document_override",
      "outdated_policy_artifacts": "ticket_and_align",
      "mirror_drift": "adopt_or_restore_through_humblecontrol"
    }
  },
  "rules": {
    "required_paths": [
      "README.md",
      "AGENTS.md",
      "docs/workflow-contract.md",
      "Scripts/validate_repo_contract.py",
      "Scripts/humble_doctor.py",
      "Scripts/validate_humble_tickets.py",
      ".humble/status/current.json",
      ".humble/tickets",
      ".humble/coordination/lanes.json",
      "script/build_and_run.sh",
      "AppleApps"
    ],
    "required_any_paths": [
      [
        "HumbleStudio.xcodeproj",
        "*.xcodeproj"
      ],
      [
        "index.html",
        "js/app.js"
      ]
    ],
    "required_commands": []
  }
}
